// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int       @id @default(autoincrement())
  username       String    @unique
  email          String    @unique
  password       String
  avatar         String?
  
  // Matches as Player1
  player1Matches Match[]   @relation("Player1Matches")
  
  // Matches as Player2
  player2Matches Match[]   @relation("Player2Matches")
  
  // Matches won
  wonMatches     Match[]   @relation("WinnerMatches")

  // Tournaments created
  tournaments    Tournament[] @relation("OrganizerTournaments")

  // Optional: achievements, stats
  achievements   Achievement[]
}

model Tournament {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  game        String
  startDate   DateTime
  maxPlayers  Int
  organizer   User      @relation("OrganizerTournaments", fields: [organizerId], references: [id])
  organizerId Int

  participants TournamentParticipant[]
  matches      Match[]
}

model TournamentParticipant {
  id           Int        @id @default(autoincrement())
  user         User       @relation(fields: [userId], references: [id])
  userId       Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  tournamentId Int

  checkedIn    Boolean    @default(false)
}

model Match {
  id        Int      @id @default(autoincrement())

  player1   User?    @relation("Player1Matches", fields: [player1Id], references: [id])
  player1Id Int?

  player2   User?    @relation("Player2Matches", fields: [player2Id], references: [id])
  player2Id Int?

  winner    User?    @relation("WinnerMatches", fields: [winnerId], references: [id])
  winnerId  Int?

  tournament Tournament @relation(fields: [tournamentId], references: [id])
  tournamentId Int

  results    MatchResult[]
}

model MatchResult {
  id       Int    @id @default(autoincrement())
  match    Match  @relation(fields: [matchId], references: [id])
  matchId  Int
  score1   Int
  score2   Int
  // Optional: reporter, timestamp
  createdAt DateTime @default(now())
}

model Achievement {
  id     Int    @id @default(autoincrement())
  user   User   @relation(fields: [userId], references: [id])
  userId Int
  title  String
  date   DateTime @default(now())
}
